<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Separator?>

<BorderPane style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="oop.controller.DashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="55.0" prefWidth="1183.0" spacing="20" style="-fx-background-color: #D3D3D3; -fx-padding: 15;">
            <Label style="-fx-font-weight: bold;" text="Inventory Management Dashboard">
                <font><Font size="24.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" onAction="#search" prefWidth="250" promptText="🔍 Search product" style="-fx-background-radius: 20; -fx-padding: 8 15;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            <HBox alignment="CENTER" spacing="20">
                <VBox alignment="CENTER" minWidth="220" spacing="5" style="-fx-background-color: #2c3e50; -fx-background-radius: 10;">
                    <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                    <Label text="Total Products" textFill="WHITE" />
                    <Label fx:id="totalProductsLabel" style="-fx-font-weight: bold;" text="0" textFill="WHITE">
                        <font><Font size="32.0" /></font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" minWidth="220" spacing="5" style="-fx-background-color: #e74c3c; -fx-background-radius: 10;">
                    <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                    <Label text="Low Stock Items" textFill="WHITE" />
                    <Label fx:id="lowStockLabel" style="-fx-font-weight: bold;" text="0" textFill="WHITE">
                        <font><Font size="32.0" /></font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" minWidth="240" spacing="5" style="-fx-background-color: #27ae60; -fx-background-radius: 10;">
                    <padding><Insets bottom="15" left="20" right="20" top="15" /></padding>
                    <Label text="Total Inventory Value" textFill="WHITE" />
                    <Label fx:id="totalValueLabel" style="-fx-font-weight: bold;" text="RM0.00" textFill="WHITE">
                        <font><Font size="32.0" /></font>
                    </Label>
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-weight: bold;" text="Inventory Summary List">
                    <font><Font size="18.0" /></font>
                </Label>
                <TableView fx:id="inventoryTable" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="130.0" text="ID" />
                        <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Product Name" />
                        <TableColumn fx:id="categoryColumn" prefWidth="140.0" text="Category" />
                        <TableColumn fx:id="quantityColumn" prefWidth="130.0" text="Quantity" />
                        <TableColumn fx:id="priceColumn" prefWidth="130.0" text="Price (RM)" />
                        <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Status" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <right>
        <VBox minWidth="360.0" prefWidth="360.0" maxWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20;" BorderPane.alignment="CENTER">

            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Dashboard Options">
                <font><Font size="18.0" /></font>
            </Label>

            <VBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-width: 1; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #495057;" text="Inventory Insights">
                    <font><Font size="14.0" /></font>
                </Label>
                <Separator />

                <BarChart fx:id="categoryBarChart" legendVisible="false" prefHeight="260.0" maxHeight="300.0" title="Products by Category" style="-fx-padding: 10 10 10 0;" VBox.vgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis fx:id="xAxis" side="BOTTOM" tickLabelRotation="0.0" animated="false" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="yAxis" side="LEFT" />
                    </yAxis>
                </BarChart>
            </VBox>

            <Region prefHeight="5.0" VBox.vgrow="NEVER" />

            <Button maxWidth="Infinity" onAction="#openManagementWindow" style="-fx-background-color: #2c3e50; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-text-fill: white; -fx-cursor: hand;" text="⚙ Manage Transactions" />
            <Button maxWidth="Infinity" onAction="#refresh" style="-fx-background-color: #3498db; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-text-fill: white; -fx-cursor: hand;" text="🔄 Refresh" />

            <Separator />

            <Button maxWidth="Infinity" onAction="#handleBackToLogin" style="-fx-background-color: #7f8c8d; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-text-fill: white; -fx-cursor: hand;" text="🚪 Log Out / Back" />
        </VBox>
    </right>
</BorderPane>