<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="oop.controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="55.0" prefWidth="1183.0" spacing="20" style="-fx-background-color: #D3D3D3; -fx-padding: 15;">
            <Label style="-fx-font-weight: bold;" text="Inventory Management Dashboard">
            <font>
                <Font size="24.0" />
            </font></Label>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" onAction="#search" prefWidth="250" promptText="🔍 Search product" style="-fx-background-radius: 20; -fx-padding: 8 15;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            
            <HBox alignment="CENTER" spacing="20">
                
                <VBox alignment="CENTER" minWidth="220" spacing="5" style="-fx-background-color: #2c3e50; -fx-background-radius: 10;">
                    <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                    <Label text="Total Products" textFill="WHITE" />
                    <Label fx:id="totalProductsLabel" style="-fx-font-weight: bold;" text="0" textFill="WHITE">
                  <font>
                      <Font size="32.0" />
                  </font></Label>
                </VBox>

                <VBox alignment="CENTER" minWidth="220" spacing="5" style="-fx-background-color: #e74c3c; -fx-background-radius: 10;">
                    <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                    <Label text="Low Stock Items" textFill="WHITE" />
                    <Label fx:id="lowStockLabel" style="-fx-font-weight: bold;" text="0" textFill="WHITE">
                  <font>
                      <Font size="32.0" />
                  </font></Label>
                </VBox>

                <VBox alignment="CENTER" minWidth="240" spacing="5" style="-fx-background-color: #27ae60; -fx-background-radius: 10;">
                    <padding><Insets bottom="15" left="20" right="20" top="15" /></padding>
                    <Label text="Total Inventory Value" textFill="WHITE" />
                    <Label fx:id="totalValueLabel" style="-fx-font-weight: bold;" text="RM0.00" textFill="WHITE">
                  <font>
                      <Font size="32.0" />
                  </font></Label>
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                
                <Label style="-fx-font-weight: bold;" text="Inventory List">
               <font>
                  <Font size="18.0" />
               </font></Label>

                <TableView fx:id="inventoryTable" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="130.00000131130219" text="ID" />
                        <TableColumn fx:id="nameColumn" prefWidth="142.66666412353516" text="Product Name" />
                        <TableColumn fx:id="categoryColumn" prefWidth="137.99993896484375" text="Category" />
                        <TableColumn fx:id="quantityColumn" prefWidth="136.00006103515625" text="Quantity" />
                        <TableColumn fx:id="priceColumn" prefWidth="124.6666259765625" text="Price (RM)" />
                        <TableColumn fx:id="statusColumn" prefWidth="158.0" text="Status" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #95a5a6;" />
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <right>
        <VBox prefWidth="280" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, -2, 0);">
            
            <Label style="-fx-font-weight: bold;" text="Add New Product">
            <font>
               <Font size="18.0" />
            </font></Label>

            <VBox spacing="5">
                <Label text="Product ID" textFill="#7f8c8d" />
                <TextField ="idField" style="-fx-background-radius: 5; -fx-padding: 10;" />
            </VBox>

            <VBox spacing="5">
                <Label text="Product Name" textFill="#7f8c8d" />
                <TextField ="nameField" style="-fx-background-radius: 5; -fx-padding: 10;" />
            </VBox>

            <VBox spacing="5">
                <Label text="Category" textFill="#7f8c8d" />
                <TextField fx:id="categoryField" style="-fx-background-radius: 5; -fx-padding: 10;" />
            </VBox>

            <VBox spacing="5">
                <Label text="Quantity" textFill="#7f8c8d" />
                <TextField fx:id="quantityField" style="-fx-background-radius: 5; -fx-padding: 10;" />
            </VBox>

            <VBox spacing="5">
                <Label text="Price (RM)" textFill="#7f8c8d" />
                <TextField fx:id="priceField" style="-fx-background-radius: 5; -fx-padding: 10;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button maxWidth="Infinity" onAction="#addProduct" style="-fx-background-color: #27ae60; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;" text="➕ Add Product" textFill="WHITE" />
            <Button maxWidth="Infinity" onAction="#delProduct" style="-fx-background-color: #e74c3c; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;" text="🗑 Delete Product" textFill="WHITE" />
            <Button maxWidth="Infinity" onAction="#refresh" style="-fx-background-color: #3498db; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;" text="🔄 Refresh" textFill="WHITE" />
        </VBox>
    </right>

</BorderPane>
